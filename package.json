{
  "name": "@fsegurai/codemirror-themes",
  "version": "6.30.0",
  "description": "Theme packages for the CodeMirror editor",
  "type": "module",
  "license": "MIT",
  "author": {
    "name": "Fabián Segura",
    "url": "https://www.fsegurai.com/"
  },
  "engines": {
    "node": ">=20",
    "bun": ">=1.3.0",
    "npm": ">=10"
  },
  "keywords": [
    "code",
    "codemirror",
    "codemirror-6",
    "diff",
    "diff-editor",
    "editor",
    "highlight",
    "javascript",
    "javascript-library",
    "library",
    "syntax",
    "typescript",
    "typescript-library",
    "themes",
    "abcdef",
    "abyss",
    "android-studio",
    "andromeda",
    "basic-dark",
    "basic-light",
    "bundle",
    "catppuccin-mocha",
    "cobalt2",
    "forest",
    "github-dark",
    "github-light",
    "gruvbox-dark",
    "gruvbox-light",
    "high-contrast-dark",
    "high-contrast-light",
    "material-dark",
    "material-light",
    "material-ocean",
    "monokai",
    "nord",
    "palenight",
    "solarized-dark",
    "solarized-light",
    "synthwave-84",
    "tokyo-night-day",
    "tokyo-night-storm",
    "volcano",
    "vscode-dark",
    "vscode-light"
  ],
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "prebuild": "bun run clean",
    "build": "bun run build:packages && bun run postbuild:packages && bun run build:demo && bun run postbuild:demo",
    "postbuild:demo": "cpy ./README.md ./demo && cpy ./LICENSE ./demo",
    "build:packages": "bun run --filter '*' pkg:build",
    "postbuild:packages": "find ./packages -maxdepth 1 -type d ! -name '.helper' ! -name 'packages' -exec cp ./LICENSE {} \\;",
    "build:demo": "rollup -c rollup.config.js",
    "build:doppler": "doppler run bun run build",
    "build:packages:doppler": "doppler run bun run build:packages",
    "build:demo:doppler": "doppler run bun run build:demo && bun run postbuild:demo",
    "clean": "bun run clean:packages && bun run clean:demo",
    "clean:packages": "rimraf --glob ./packages/*/dist",
    "clean:demo": "rimraf --glob ./demo/dist ./demo/README.md ./demo/LICENSE",
    "clean:coverage": "rimraf --glob ./coverage",
    "dev": "rollup -w -c rollup.config.js",
    "dev:doppler": "doppler run bun run dev",
    "start": "bun run dev",
    "start:doppler": "bun run dev:doppler",
    "lint": "bun run lint:packages && bun run lint:demo",
    "lint:check": "eslint . --max-warnings 0",
    "lint:fix": "bun run lint:packages --fix && bun run lint:demo --fix",
    "lint:packages": "eslint ./packages/*/src/**",
    "lint:demo": "eslint ./demo",
    "generate:helpers": "bun packages/.helper/utils/generate-utils.ts",
    "generate:readme": "bun packages/.helper/docs/generate-readme.ts",
    "version:update": "bun packages/.helper/versions/update-packages-versions.ts --write",
    "version:preview": "bun packages/.helper/versions/update-packages-versions.ts --dry-run",
    "version:skip": "bun packages/.helper/versions/update-packages-versions.ts --dry-run --skip '@fsegurai/codemirror-theme-bundle'"
  },
  "dependencies": {
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "6.12.3",
    "@codemirror/language-data": "^6.5.2",
    "@codemirror/legacy-modes": "^6.5.2",
    "@codemirror/merge": "^6.12.1",
    "@codemirror/state": "^6.6.0",
    "@lezer/markdown": "1.6.3",
    "@material/web": "^2.4.1",
    "clipboard": "^2.0.11",
    "codemirror": "^6.0.2",
    "marked": "^17.0.5",
    "marked-highlight": "^2.2.3",
    "prismjs": "^1.30.0"
  },
  "devDependencies": {
    "@codemirror/buildhelper": "^1.0.2",
    "@eslint/js": "10.0.1",
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-replace": "^6.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/node": "25.5.0",
    "@types/prismjs": "^1.26.6",
    "cpy-cli": "^7.0.0",
    "dotenv": "^17.4.0",
    "eslint": "10.1.0",
    "glob": "^13.0.6",
    "globals": "17.4.0",
    "rimraf": "^6.1.3",
    "rollup": "4.60.1",
    "rollup-plugin-dev": "^2.1.0",
    "typescript": "6.0.2",
    "typescript-eslint": "8.58.0"
  }
}
